// ----- REGRESIÓN LINEAL -----
X = [1,2,3,4,5];
Y = [2,4,5,7,8];
modelo_lineal = linearRegression(X, Y);
prediccion_lineal = predecir(modelo_lineal, [6]);
print("\n===== REGRESIÓN LINEAL =====");
print("  Predicción para X=6:", prediccion_lineal);

// ----- REGRESIÓN LOGÍSTICA (ejemplo simple) -----
X_log = [1,2,3,4,5,6];
Y_log = [0,0,0,1,1,1];
modelo_log = logisticRegression(X_log, Y_log);
pred_log = predecir(modelo_log, [2.5]);
print("\n===== REGRESIÓN LOGÍSTICA =====");
print("  Probabilidad para X=2.5:", pred_log);

// ----- PERCEPTRÓN MULTICAPA (XOR) -----
X_xor = [0,0; 0,1; 1,0; 1,1];
Y_xor = [0,1,1,0];
clf = perceptron(X_xor, Y_xor, [4,2]);   // dos capas ocultas de 4 y 2 neuronas
print("\n===== PERCEPTRÓN MULTICAPA =====");
print("  Predicción XOR para [0,0]:", predecir(clf, [0,0]));
print("  Predicción XOR para [0,1]:", predecir(clf, [0,1]));
print("  Predicción XOR para [1,0]:", predecir(clf, [1,0]));
print("  Predicción XOR para [1,1]:", predecir(clf, [1,1]));

// ----- USO DE CONSTANTES -----
print("\n===== CONSTANTES =====");
print("  PI:", PI);
print("  E:", E);
