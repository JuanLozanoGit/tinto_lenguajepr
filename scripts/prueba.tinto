// ==================================================
// PRUEBA COMPLETA DEL LENGUAJE TINTO
// ==================================================

// ----- OPERACIONES ARITMÉTICAS BÁSICAS -----
a = 10;
b = 3;
suma = a + b;
resta = a - b;
multi = a * b;
div = a / b;
mod = a % b;
pot = a ^ 2;
raiz = sqrt(16);   // también puedes usar raiz(16)

print("===== ARITMÉTICA =====");
print("  suma:", suma);
print("  resta:", resta);
print("  multiplicación:", multi);
print("  división:", div);
print("  módulo:", mod);
print("  potencia:", pot);
print("  raíz cuadrada:", raiz);

// ----- MATRICES -----
m1 = [1,2;3,4];
m2 = [5,6;7,8];
m_suma = m1 + m2;
m_multi = m1 * m2;          // producto matricial
m_trans = transpose(m1);
m_inv = inverse(m1);

print("\n===== MATRICES =====");
print("  m1:", m1);
print("  m2:", m2);
print("  suma:", m_suma);
print("  multiplicación matricial:", m_multi);
print("  transpuesta:", m_trans);
print("  inversa (aprox):", m_inv);

// ----- CONDICIONALES -----
x = 5;
print("\n===== CONDICIONAL =====");
if (x > 3) {
    print("  x es mayor que 3");
} else {
    print("  x no es mayor que 3");
}

// ----- BUCLES -----
print("\n===== BUCLE FOR =====");
for i = 1 to 5 {
    print("  i =", i);
}

print("\n===== BUCLE WHILE =====");
j = 0;
while (j < 3) {
    print("  j =", j);
    j = j + 1;
}

// ----- FUNCIONES MATEMÁTICAS -----
angulo = 30 * PI / 180;   // 30 grados a radianes
print("\n===== FUNCIONES MATEMÁTICAS =====");
print("  seno(30°):", sin(angulo));
print("  coseno(30°):", cos(angulo));
print("  tangente(30°):", tan(angulo));
print("  logaritmo natural de 2:", log(2));

